    {
      "name": "Update allowed fields",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Retailer updated successfully\", function () {",
              "    const jsonData = pm.response.json();",
              "",
              "    // API returns the retailer object at the top-level (but keep compatibility if wrapped in { data })",
              "    const retailer = jsonData.data || jsonData;",
              "",
              "    pm.expect(retailer).to.be.an(\"object\");",
              "",
              "    // Validate allowed fields",
              "    pm.expect(retailer.points, \"points\").to.equal(150);",
              "    pm.expect(retailer.routes, \"routes\").to.equal(\"Route B\");",
              "    pm.expect(retailer.notes, \"notes\").to.equal(\"Some note here!\");",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
