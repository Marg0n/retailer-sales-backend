              "const jsonData = pm.response.json();",
              "console.log(\"RETAILER LIST RESPONSE:\", jsonData);",
              "",
              "const retailers =",
              "  Array.isArray(jsonData) ? jsonData :",
              "  jsonData.data && Array.isArray(jsonData.data) ? jsonData.data :",
              "  jsonData.retailers && Array.isArray(jsonData.retailers) ? jsonData.retailers :",
              "  jsonData.data?.retailers && Array.isArray(jsonData.data.retailers) ? jsonData.data.retailers :",
              "  [];",
              "",
              "pm.test(\"Retailer response is an array\", function () {",
              "  pm.expect(retailers).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"Retailer list returned\", function () {",
              "  pm.expect(retailers.length).to.be.greaterThan(0);",
              "});",
              "",
              "if (retailers.length > 0) {",
              "  pm.environment.set(\"uid\", retailers[0].uid);",
