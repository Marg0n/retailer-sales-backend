              "",
              "pm.test(\"Response is an array or has data array\", function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.exist;",
              "});",
              "",
              "pm.test(\"Retailer list returned\", function () {",
              "  const jsonData = pm.response.json();",
              "",
              "  if (Array.isArray(jsonData)) {",
              "    pm.expect(jsonData.length).to.be.greaterThan(0);",
              "    pm.environment.set(\"retailerUid\", jsonData[0].uid);",
              "  } else if (jsonData.data && Array.isArray(jsonData.data)) {",
              "    pm.expect(jsonData.data.length).to.be.greaterThan(0);",
              "    pm.environment.set(\"retailerUid\", jsonData.data[0].uid);",
              "  }",
              "});"
